# 未设置时 API 使用进程内存储，仅适用于本地演示。
DATABASE_URL=mysql://zhansite:change-me@localhost:3306/zhansite
# 仅供集成测试；数据库名必须以 _test 结尾，测试会清空其中的 Phase 2 表。
DATABASE_URL_TEST=mysql://zhansite:change-me@localhost:3306/zhansite_test
PORT=8787
DEV_ACTOR_ID=local-operator
ADMIN_ORIGIN=http://localhost:5173
# 独立 Worker 运行时设为 false，避免 API 进程重复消费部署任务。
RUN_EMBEDDED_DEPLOYMENT_WORKER=true
# 独立 Worker 轮询间隔，允许 100～60000 毫秒。
DEPLOYMENT_WORKER_POLL_MS=1000

# 未完整配置 OSS 时使用进程内对象存储，只支持本地上传验证，不会生成 HTTPS 预览。
UPLOAD_TOKEN_SECRET=replace-with-at-least-32-random-characters
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=replace-with-test-bucket
OSS_ACCESS_KEY_ID=replace-with-ram-access-key-id
OSS_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
# 可选：自定义 OSS endpoint。
OSS_ENDPOINT=
# Asset 可读取的 HTTPS 基础 URL，例如 CDN 域名；末尾不带 /。
OSS_PUBLIC_BASE_URL=https://assets.example.com
# 仅填根域名，例如 example.com；预览格式为 https://{siteId}.preview.{PLATFORM_DOMAIN}。
PLATFORM_DOMAIN=example.com
